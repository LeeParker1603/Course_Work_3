Использовано 87 % доступного пространства. … Когда место закончится, вы не сможете создавать, редактировать и загружать файлы. Используйте 100 ГБ в хранилище совместно с участниками семейной группы за 139 ₽ 35 ₽ в течение 3 месяцев.
[flake8]
# Игнорируемые ошибки (например, E203 для совместимости с Black)
ignore = E203, E266, E501, W503
# Максимальная длина строки
max-line-length = 119
# Максимальная цикломатическая сложность кода
max-complexity = 10
# Папки и файлы, которые не нужно проверять
exclude =
    .git,
    __pycache__,
    build,
    dist,
    venv,
    .venv